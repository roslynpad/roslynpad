<Project>
  <!--
    IgnoresAccessChecksToGenerator emits both the [assembly: IgnoresAccessChecksTo(...)] attributes
    and the (internal) attribute class definition into every consuming project. Projects that also
    receive InternalsVisibleTo from another consuming project would see two definitions (CS0436).
    Opting in via IgnoresAccessChecksToOmitAttributeDefinition compiles only the assembly-level
    attributes (still required by the runtime) and uses the attribute class defined by a referenced
    assembly through InternalsVisibleTo. The Substring call fails the build if the generated file's
    shape ever changes.
  -->
  <Target Name="OmitIgnoresAccessChecksToAttributeDefinition"
          AfterTargets="IgnoresAccessChecksToGenerator"
          Condition=" '$(IgnoresAccessChecksToOmitAttributeDefinition)' == 'true' And Exists('$(_IACTG_CodeFilePath)') ">
    <PropertyGroup>
      <_IACTG_FullText>$([System.IO.File]::ReadAllText('$(_IACTG_CodeFilePath)'))</_IACTG_FullText>
      <_IACTG_AttributesOnlyText>$(_IACTG_FullText.Substring(0, $(_IACTG_FullText.IndexOf('namespace System.Runtime.CompilerServices'))))</_IACTG_AttributesOnlyText>
      <_IACTG_AttributesOnlyFilePath>$(_IACTG_IntermediatePath)/IgnoresAccessChecksTo.AttributesOnly.cs</_IACTG_AttributesOnlyFilePath>
    </PropertyGroup>
    <WriteLinesToFile File="$(_IACTG_AttributesOnlyFilePath)" Lines="$(_IACTG_AttributesOnlyText)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <Compile Remove="$(_IACTG_CodeFilePath)" />
      <Compile Include="$(_IACTG_AttributesOnlyFilePath)" />
    </ItemGroup>
  </Target>
  <ItemGroup Condition=" '$(CopyRoslynPadRuntimeAssemblies)' == 'true' ">
    <ProjectReference Include="$(RepoRoot)src\RoslynPad.Runtime\RoslynPad.Runtime.csproj" SetTargetFramework="TargetFramework=$(EarliestSupportedTargetFramework)" ReferenceOutputAssembly="false" GlobalPropertiesToRemove="RuntimeIdentifier" />
    <ProjectReference Include="$(RepoRoot)src\RoslynPad.Runtime\RoslynPad.Runtime.csproj" SetTargetFramework="TargetFramework=netstandard2.0" ReferenceOutputAssembly="false" GlobalPropertiesToRemove="RuntimeIdentifier" />
  </ItemGroup>
  <Target Name="CopyRoslynPadRuntimeAssembliesOnBuild" AfterTargets="Build"
          Condition=" '$(CopyRoslynPadRuntimeAssemblies)' == 'true' And '$(IsMacBuild)' != 'true' ">
    <Copy SourceFiles="$(RepoRoot)src\RoslynPad.Runtime\bin\$(Configuration)\$(EarliestSupportedTargetFramework)\RoslynPad.Runtime.dll" DestinationFolder="$(OutputPath)\runtimes\net" />
    <Copy SourceFiles="$(RepoRoot)src\RoslynPad.Runtime\bin\$(Configuration)\netstandard2.0\RoslynPad.Runtime.dll" DestinationFolder="$(OutputPath)\runtimes\netfx" />
  </Target>
  <Target Name="CopyRoslynPadRuntimeAssembliesIntoAppBundle" BeforeTargets="_CodesignAppBundle"
          Condition=" '$(CopyRoslynPadRuntimeAssemblies)' == 'true' And '$(IsMacBuild)' == 'true' ">
    <Copy SourceFiles="$(RepoRoot)src\RoslynPad.Runtime\bin\$(Configuration)\$(EarliestSupportedTargetFramework)\RoslynPad.Runtime.dll" DestinationFolder="$(AppBundleDir)\Contents\MonoBundle\runtimes\net" />
    <Copy SourceFiles="$(RepoRoot)src\RoslynPad.Runtime\bin\$(Configuration)\netstandard2.0\RoslynPad.Runtime.dll" DestinationFolder="$(AppBundleDir)\Contents\MonoBundle\runtimes\netfx" />
  </Target>
  <Target Name="CopyRoslynPadRuntimeAssembliesOnPublish" AfterTargets="Publish"
          Condition=" '$(CopyRoslynPadRuntimeAssemblies)' == 'true' And '$(IsMacBuild)' != 'true' ">
    <Copy SourceFiles="$(RepoRoot)src\RoslynPad.Runtime\bin\$(Configuration)\$(EarliestSupportedTargetFramework)\RoslynPad.Runtime.dll" DestinationFolder="$(PublishDir)\runtimes\net" />
    <Copy SourceFiles="$(RepoRoot)src\RoslynPad.Runtime\bin\$(Configuration)\netstandard2.0\RoslynPad.Runtime.dll" DestinationFolder="$(PublishDir)\runtimes\netfx" />
  </Target>
  <!-- hack to make macOS asset packaging (actool) work on non-Catalyst builds -->
  <Target Name="Before_CoreCompileImageAssets" BeforeTargets="_CoreCompileImageAssets">
    <PropertyGroup>
      <Original_SdkPlatform>$(_SdkPlatform)</Original_SdkPlatform>
      <_SdkPlatform>MacCatalyst</_SdkPlatform>
      <Original_UIDeviceFamily>$(_UIDeviceFamily)</Original_UIDeviceFamily>
      <_UIDeviceFamily>IPad</_UIDeviceFamily>
      <Original_ComputedTargetFrameworkMoniker>$(_ComputedTargetFrameworkMoniker)</Original_ComputedTargetFrameworkMoniker>
      <_ComputedTargetFrameworkMoniker>$(_ComputedTargetFrameworkMoniker.Replace('=macos', '=maccatalyst'))</_ComputedTargetFrameworkMoniker>
    </PropertyGroup>
  </Target>
  <Target Name="After_CoreCompileImageAssets" AfterTargets="_CoreCompileImageAssets">
    <PropertyGroup>
      <_SdkPlatform>$(Original_SdkPlatform)</_SdkPlatform>
      <_UIDeviceFamily>$(Original_UIDeviceFamily)</_UIDeviceFamily>
      <_ComputedTargetFrameworkMoniker>$(Original_ComputedTargetFrameworkMoniker)</_ComputedTargetFrameworkMoniker>
    </PropertyGroup>
  </Target>
</Project>
