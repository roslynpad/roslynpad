<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:RoslynPad.UI"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="500"
             x:Class="RoslynPad.SecretsView"
             x:DataType="ui:SecretsViewModel">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Directory -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Secrets Directory"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Directory, Mode=OneWay}"
                     IsReadOnly="True" />
        </StackPanel>

        <!-- Add Button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Add Secret"
                    Command="{Binding AddCommand}"
                    Padding="8,4" />
        </StackPanel>

        <!-- Error -->
        <TextBlock Grid.Row="2"
                   Text="{Binding Error}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Secrets List -->
        <ScrollViewer Grid.Row="3">
            <ItemsControl Name="SecretsItemsControl" ItemsSource="{Binding Secrets}"
                         Grid.IsSharedSizeScope="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type ui:SecretItemViewModel}">
                        <Border BorderBrush="Gray"
                                BorderThickness="0,0,0,1"
                                Padding="5,8">
                            <Panel>
                                <!-- Editing row -->
                                <Grid ColumnDefinitions="*,*,Auto,Auto"
                                      IsVisible="{Binding IsEditing}">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding EditName}"
                                             PlaceholderText="Name"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center" />

                                    <TextBox Grid.Column="1"
                                             Text="{Binding EditValue}"
                                             PlaceholderText="Value"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Content="Save"
                                            Command="{Binding #SecretsItemsControl.((ui:SecretsViewModel)DataContext).SaveNewSecretCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4"
                                            VerticalAlignment="Center" />

                                    <Button Grid.Column="3"
                                            Content="Cancel"
                                            Command="{Binding #SecretsItemsControl.((ui:SecretsViewModel)DataContext).CancelNewSecretCommand}"
                                            CommandParameter="{Binding}"
                                            Margin="5,0,0,0"
                                            Padding="8,4"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <!-- Display row -->
                                <Grid IsVisible="{Binding !IsEditing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SecretName" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />

                                    <!-- Value TextBox: read-only dots when hidden, editable when revealed -->
                                    <TextBox Grid.Column="1"
                                             Text="••••••••"
                                             IsReadOnly="True"
                                             CopyingToClipboard="OnCopyingToClipboard"
                                             IsVisible="{Binding !IsRevealed}"
                                             VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding EditableValue}"
                                             IsVisible="{Binding IsRevealed}"
                                             VerticalAlignment="Center" />

                                    <ToggleButton Grid.Column="2"
                                                  IsChecked="{Binding IsRevealed}"
                                                  Margin="5,0"
                                                  Padding="4"
                                                  VerticalAlignment="Center">
                                        <Panel>
                                            <Image Source="{DynamicResource Visible}" Width="16" Height="16"
                                                   IsVisible="{Binding !IsRevealed}" />
                                            <Image Source="{DynamicResource VisibleFilled}" Width="16" Height="16"
                                                   IsVisible="{Binding IsRevealed}" />
                                        </Panel>
                                    </ToggleButton>

                                    <!-- Save button: only visible when revealed -->
                                    <Button Grid.Column="3"
                                            Command="{Binding #SecretsItemsControl.((ui:SecretsViewModel)DataContext).SaveValueCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding IsRevealed}"
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <Image Source="{DynamicResource Save}" Width="16" Height="16" />
                                    </Button>

                                    <Button Grid.Column="4"
                                            Command="{Binding #SecretsItemsControl.((ui:SecretsViewModel)DataContext).CopyCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <Image Source="{DynamicResource Copy}" Width="16" Height="16" />
                                    </Button>

                                    <Button Grid.Column="5"
                                            Command="{Binding #SecretsItemsControl.((ui:SecretsViewModel)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}"
                                            Margin="5,0"
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <Image Source="{DynamicResource Delete}" Width="16" Height="16" />
                                    </Button>
                                </Grid>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
