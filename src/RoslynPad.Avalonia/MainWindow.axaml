<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RoslynPad.MainWindow"
        xmlns:AvalonEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:local="clr-namespace:RoslynPad;assembly=RoslynPad"
        xmlns:roslyn="clr-namespace:Microsoft.CodeAnalysis;assembly=Microsoft.CodeAnalysis"
        xmlns:ui="clr-namespace:RoslynPad.UI;assembly=RoslynPad.Common.UI"
        xmlns:dialogHost="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        MinWidth="500"
        MinHeight="300"
        x:DataType="local:MainViewModelAvalonia"
        Title="{Binding WindowTitle, Mode=OneTime}"
        Icon="avares://RoslynPad/Resources/RoslynPad.ico"
        Name="This">
  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="File">
        <NativeMenu>
          <NativeMenuItem Header="New Document" Gesture="Meta+N"
                          Click="OnNewDocumentClick" />
          <NativeMenuItem Header="New Script" Gesture="Meta+Shift+N"
                          Click="OnNewScriptClick" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Open..." Gesture="Meta+O"
                          Command="{Binding OpenFileCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Save" Gesture="Meta+S"
                          Click="OnSaveClick" />
          <NativeMenuItem Header="Close" Gesture="Meta+W"
                          Command="{Binding CloseCurrentDocumentCommand}" />
        </NativeMenu>
      </NativeMenuItem>
      <NativeMenuItem Header="Edit">
        <NativeMenu>
          <NativeMenuItem Header="Find" Gesture="Meta+F"
                          Click="OnFindClick" />
          <NativeMenuItem Header="Replace" Gesture="Meta+Alt+F"
                          Click="OnReplaceClick" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Format Document" Gesture="Meta+D"
                          Click="OnFormatDocumentClick" />
          <NativeMenuItem Header="Comment Selection" Gesture="Meta+K"
                          Click="OnCommentSelectionClick" />
          <NativeMenuItem Header="Uncomment Selection" Gesture="Meta+U"
                          Click="OnUncommentSelectionClick" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Rename Symbol" Gesture="F2"
                          Click="OnRenameSymbolClick" />
        </NativeMenu>
      </NativeMenuItem>
      <NativeMenuItem Header="Run">
        <NativeMenu>
          <NativeMenuItem Header="Run" Gesture="F5"
                          Click="OnRunClick" />
          <NativeMenuItem Header="Terminate" Gesture="Shift+F5"
                          Click="OnTerminateClick" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Toggle Live Mode"
                          Click="OnToggleLiveModeClick" />
        </NativeMenu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>
  <dialogHost:DialogHost x:Name="DiaglogHost" Identifier="Main" CloseOnClickAway="True" DisableOpeningAnimation="True">
    <DockPanel>

      <Button Padding="3"
                Margin="1"
                Background="#eebbbb"
                DockPanel.Dock="Bottom"
                Click="OnErrorButtonClick"
                VerticalAlignment="Stretch"
                IsVisible="{Binding HasError}">
          <TextBlock VerticalAlignment="Center"
                     Text="{Binding LastError.Message}" />
      </Button>

      <Border DockPanel.Dock="Bottom"
              Padding="4 2"
              Background="{DynamicResource {x:Static local:ThemeDictionary.StatusBarBackground}}">
        <DockPanel LastChildFill="False">
          <StackPanel DockPanel.Dock="Right"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      TextBlock.Foreground="{DynamicResource {x:Static local:ThemeDictionary.StatusBarForeground}}">

            <ToggleButton Margin="10 0 0 0"
                          BorderThickness="0"
                          Background="Transparent"
                          Padding="2"
                          IsChecked="{Binding Settings.OptimizeCompilation}"
                          ToolTip.Tip="{OnPlatform Optimization (Ctrl+Shift+O), macOS=Optimization (⌘ ⇧ O)}">
              <Image Source="{StaticResource Time}"
                     Width="14"
                     Height="14" />
            </ToggleButton>

            <Image Margin="10 0 0 0"
                   Source="{StaticResource FontSize}"
                   Height="14"
                   Width="14" />
            <Slider Width="100"
                    ToolTip.Tip="Font Size"
                    Margin="5 0 0 0"
                    Minimum="{x:Static ui:MainViewModel.MinimumFontSize}"
                    Maximum="{x:Static ui:MainViewModel.MaximumFontSize}"
                    SmallChange="1"
                    LargeChange="10"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Value="{Binding EditorFontSize}" />
            <TextBlock Text="{Binding EditorFontSize}"
                       Margin="5 0 0 0"
                       VerticalAlignment="Center"
                       FontSize="12" />

          </StackPanel>
        </DockPanel>
      </Border>

      <DockControl x:Name="Dock" InitializeLayout="True" InitializeFactory="True">
        <DockControl.Factory>
          <Factory ActiveDockableChanged="OnActiveDockableChanged"
                   DockableClosed="OnDockableClosedAsync" />
        </DockControl.Factory>

        <RootDock x:Name="Root" Id="Root" IsCollapsable="False" DefaultDockable="{Binding #MainLayout}">

          <ProportionalDock x:Name="MainLayout" Id="MainLayout" Orientation="Horizontal">

            <ToolDock x:Name="LeftPane" Id="LeftPane" Proportion="0.25" Alignment="Left">
              <Tool x:Name="Documents" Id="Documents" Title="Documents" x:DataType="Tool" CanFloat="False" CanPin="True" CanClose="False">
                <local:DocumentTreeView x:Name="DocumentTreeView" DataContext="{Binding #This.DataContext}" />
              </Tool>
            </ToolDock>

            <ProportionalDockSplitter x:Name="LeftSplitter" Id="LeftSplitter" />

            <ProportionalDock x:Name="MainPane" Id="MainPane" Orientation="Vertical">

              <DocumentDock x:Name="DocumentsPane" Id="DocumentsPane">
                <DocumentDock.DocumentTemplate>
                  <DocumentTemplate x:CompileBindings="false">
                    <local:DocumentView DataContext="{Binding DataContext}" />
                  </DocumentTemplate>
                </DocumentDock.DocumentTemplate>
                <Document x:Name="NewDoc" Id="NewDoc" Title="Home" x:DataType="Document" CanClose="False" CanFloat="False">
                  <local:NewDocumentView DataContext="{Binding #This.DataContext}" />
                </Document>
              </DocumentDock>

               <ProportionalDockSplitter x:Name="ResultSplitter" Id="ResultSplitter" />


                <ToolDock x:Name="ResultPane" Id="ResultPane" Proportion="0.35" Alignment="Bottom">
                  <Tool x:Name="Results" Id="Results" Title="Results" x:DataType="Tool" CanFloat="False" CanPin="True" CanClose="False">
                      <local:ResultsView x:Name="ResultsView" DataContext="{Binding #This.ViewModel.CurrentOpenDocument}" />
                  </Tool>
                  <Tool x:Name="IL" Id="IL" Title="IL" x:DataType="Tool" CanFloat="False" CanPin="True" CanClose="False">
                      <local:ILViewer x:Name="ILViewer" Text="{Binding #This.ViewModel.CurrentOpenDocument.ILText}"
                                      EditorFontFamily="{Binding #This.ViewModel.Settings.EditorFontFamily}"
                                      FontSize="{Binding #This.ViewModel.EditorFontSize}" />
                  </Tool>
              </ToolDock>

            </ProportionalDock>

          </ProportionalDock>
        </RootDock>

      </DockControl>

    </DockPanel>
  </dialogHost:DialogHost>

</Window>
