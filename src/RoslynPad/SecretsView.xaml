<UserControl x:Class="RoslynPad.SecretsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="clr-namespace:RoslynPad.UI;assembly=RoslynPad.Common.UI"
             xmlns:rp="clr-namespace:RoslynPad"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance ui:SecretsViewModel}"
             d:DesignHeight="400"
             d:DesignWidth="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Directory -->
        <StackPanel Grid.Row="0"
                Margin="0,0,0,10">
            <TextBlock Text="Secrets Directory"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBox Text="{Binding Directory, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="{DynamicResource {x:Static rp:ThemeDictionary.InputBackground}}"
                     Foreground="{DynamicResource {x:Static rp:ThemeDictionary.InputForeground}}"/>
        </StackPanel>

        <!-- Add Button -->
        <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Margin="0,0,0,10">
            <Button Content="Add Secret"
                    Command="{Binding AddCommand}"
                    Padding="8,4"/>
        </StackPanel>

        <!-- Error -->
        <TextBlock Grid.Row="2"
                   Text="{Binding Error}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Secrets List -->
        <ItemsControl Grid.Row="3"
                      Grid.IsSharedSizeScope="True"
                      ItemsSource="{Binding Secrets}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type ui:SecretItemViewModel}">
                    <Border BorderBrush="Gray"
                            BorderThickness="0,0,0,1"
                            Padding="5,8">
                        <Grid>
                            <!-- Editing row -->
                            <Grid Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="SecretName"
                                         Background="{DynamicResource {x:Static rp:ThemeDictionary.InputBackground}}"
                                         Foreground="{DynamicResource {x:Static rp:ThemeDictionary.InputForeground}}"
                                         Margin="0,0,5,0"
                                         VerticalAlignment="Center"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"
                                         Background="{DynamicResource {x:Static rp:ThemeDictionary.InputBackground}}"
                                         Foreground="{DynamicResource {x:Static rp:ThemeDictionary.InputForeground}}"
                                         Margin="0,0,5,0"
                                         VerticalAlignment="Center"/>

                                <Button Grid.Column="2"
                                        Content="Save"
                                        Command="{Binding DataContext.SaveNewSecretCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4"
                                        VerticalAlignment="Center"/>

                                <Button Grid.Column="3"
                                        Content="Cancel"
                                        Command="{Binding DataContext.CancelNewSecretCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="5,0,0,0"
                                        Padding="8,4"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Display row -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}"
                                                    Value="True">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SecretName"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <!-- Value TextBox: read-only dots when hidden, editable when revealed -->
                                <TextBox Grid.Column="1"
                                         VerticalAlignment="Center"
                                         CommandManager.PreviewExecuted="DisableCopyCommand"
                                         Background="{DynamicResource {x:Static rp:ThemeDictionary.InputBackground}}"
                                         Foreground="{DynamicResource {x:Static rp:ThemeDictionary.InputForeground}}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Text" Value="••••••••"/>
                                            <Setter Property="IsReadOnly" Value="True"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                    <Setter Property="Text" Value="{Binding EditableValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Setter Property="IsReadOnly" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <ToggleButton Grid.Column="2"
                                              IsChecked="{Binding IsRevealed}"
                                              Margin="5,0"
                                              Padding="4"
                                              VerticalAlignment="Center">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <Image Source="{StaticResource Visible}" Width="16" Height="16"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <Image Source="{StaticResource VisibleFilled}" Width="16" Height="16"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>

                                <!-- Save button: only visible when revealed -->
                                <Button Grid.Column="3"
                                        Command="{Binding DataContext.SaveValueCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Image Source="{StaticResource Save}" Width="16" Height="16"/>
                                </Button>

                                <Button Grid.Column="4"
                                        Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <Image Source="{StaticResource Copy}" Width="16" Height="16"/>
                                </Button>

                                <Button Grid.Column="5"
                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="5,0"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <Image Source="{StaticResource Delete}" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
