<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType Condition=" '$(IsWindowsBuild)' == 'true' ">WinExe</OutputType>
    <OutputType Condition=" '$(IsWindowsBuild)' != 'true' ">Exe</OutputType>
    <AssemblyName>RoslynPad</AssemblyName>
    <RootNamespace>RoslynPad</RootNamespace>
    <ApplicationId>net.roslynpad</ApplicationId>
    <ApplicationTitle>RoslynPad</ApplicationTitle>
    <ApplicationIcon>Resources/RoslynPad.ico</ApplicationIcon>
    <Version>$(RoslynPadVersion)</Version>
    <CopyRoslynPadRuntimeAssemblies>true</CopyRoslynPadRuntimeAssemblies>
    <SelfContained>false</SelfContained>
    <CreatePackage>false</CreatePackage>
    <LinkMode>None</LinkMode>
    <TrimMode>partial</TrimMode>
    <IgnoresAccessChecksToOmitAttributeDefinition>true</IgnoresAccessChecksToOmitAttributeDefinition>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsMacBuild)' == 'true'">
    <TargetFramework>$(DefaultTargetFramework)-macos</TargetFramework>
    <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsMacBuild)' == 'true' and '$(SignMacBundle)' == 'true'">
    <EnableCodeSigning>true</EnableCodeSigning>
    <CodesignKey>Developer ID Application</CodesignKey>
    <UseHardenedRuntime>true</UseHardenedRuntime>
    <UseSecureTimestamp>true</UseSecureTimestamp>
  </PropertyGroup>
  <!-- hack to force resizetizer to work outside of MAUI -->
  <PropertyGroup Condition=" '$(IsMacBuild)' == 'true' ">
    <_ResizetizerIsiOSApp>true</_ResizetizerIsiOSApp>
    <ResizetizerIncludeSelfProject>true</ResizetizerIncludeSelfProject>
    <OptimizePNGs>true</OptimizePNGs>
    <_XSAppIconAssets>Assets.xcassets/appicon.appiconset</_XSAppIconAssets>
  </PropertyGroup>
  <ItemGroup>
    <MauiIcon Include="$(RepoRoot)/deploy/resources/macos/appicon.svg" />
    <AvaloniaResource Include="Resources\RoslynPad.ico" />
    <AvaloniaXaml Remove="bin\**\*.axaml;obj\**\*.axaml" />
    <EmbeddedResource Include="Editor\Resources\*.json" LogicalName="RoslynPad.Editor.Resources.%(Filename)%(Extension)" />
  </ItemGroup>
  <!-- Microsoft.CodeAnalysis.Remote.Workspaces (VisualStudioMefHostServices) and
       Microsoft.CodeAnalysis.LanguageServer.Protocol are only on the Azure DevOps feeds;
       RestoreHelper restores them and hands back raw Reference items. -->
  <ItemGroup>
    <ProjectReference Include="..\RestoreHelper\RestoreHelper.csproj" Targets="GetLibReferences" PrivateAssets="All" />
  </ItemGroup>
  <Target Name="GetLibReferences" AfterTargets="ResolveFrameworkReferences">
    <MSBuild Projects="..\RestoreHelper\RestoreHelper.csproj" Targets="GetLibReferences">
      <Output ItemName="LibReference" TaskParameter="TargetOutputs" />
    </MSBuild>
    <ItemGroup>
      <Reference Include="@(LibReference)" />
    </ItemGroup>
  </Target>
  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="DialogHost.Avalonia" />
    <PackageReference Include="ICSharpCode.Decompiler" />
    <PackageReference Include="Dock.Avalonia" />
    <PackageReference Include="Dock.Model.Avalonia" />
    <PackageReference Include="Dock.Avalonia.Themes.Fluent" />
    <PackageReference Include="IgnoresAccessChecksToGenerator" PrivateAssets="All" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" />
    <PackageReference Include="Microsoft.Maui.Resizetizer" />
    <PackageReference Include="Microsoft.VisualStudio.Composition" />
    <PackageReference Include="Mono.Cecil" />
    <PackageReference Include="Nerdbank.Streams" />
    <PackageReference Include="NuGet.Commands" />
    <PackageReference Include="NuGet.Versioning" />
    <PackageReference Include="System.Composition" />
    <PackageReference Include="System.Reactive.Core" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\RoslynPad.Runtime\RoslynPad.Runtime.csproj"
      SetTargetFramework="TargetFramework=$(EarliestSupportedTargetFramework)"
      GlobalPropertiesToRemove="RuntimeIdentifier" />
    <ProjectReference Include="..\RoslynPad.Runtime.Secrets\RoslynPad.Runtime.Secrets.csproj" />
    <ProjectReference Include="..\RoslynPad.Themes\RoslynPad.Themes.csproj" />
    <ProjectReference Include="..\Morgania.CodeAnalysis.Editor\Morgania.CodeAnalysis.Editor.csproj" />
  </ItemGroup>
  <!-- Roslyn internals used by the host layer (Roslyn/) and the editor integration:
       parse/compilation internals, Roslyn.Utilities, VisualStudioMefHostServices, … -->
  <ItemGroup>
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.CSharp" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.Features" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.CSharp.Features" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.Scripting" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.CSharp.Scripting" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.Workspaces" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.CSharp.Workspaces" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.Remote.Workspaces" />
    <IgnoresAccessChecksTo Include="Microsoft.CodeAnalysis.LanguageServer.Protocol" />
  </ItemGroup>
  <ItemGroup>
    <Compile Update="ResultsView.axaml.cs">
      <DependentUpon>ResultsView.axaml</DependentUpon>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\RoslynPad.Themes\Themes\*.json"
      Exclude="..\RoslynPad.Themes\Themes\vs2019*.json" />
  </ItemGroup>
</Project>